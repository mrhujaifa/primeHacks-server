DATABASE_URL=postgresql://username:password@localhost:5432/database_name
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://your-frontend-domain.vercel.app
CORS_ORIGINS=https://your-frontend-domain.vercel.app,https://your-preview-frontend-domain.vercel.app
ACCESS_TOKEN_SECRET=replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRES_IN=1d
REFRESH_TOKEN_SECRET=replace-with-another-long-random-string
REFRESH_TOKEN_EXPIRES_IN=7d
BETTER_AUTH_SECRET=replace-with-a-long-random-string
BETTER_AUTH_URL=https://your-backend-domain.vercel.app
RUN_PRISMA_MIGRATIONS=true
