model Hackathon {
    id                 String          @id @default(cuid())
    title              String
    slug               String          @unique
    shortDescription   String
    fullDescription    String
    bannerImageUrl     String?
    prizePoolText      String?
    registrationFee    Decimal         @default(0) @db.Decimal(10, 2)
    currency           String          @default("BDT")
    submissionDeadline DateTime
    status             HackathonStatus @default(DRAFT)
    isFeatured         Boolean         @default(false)
    isPremiumOnly      Boolean         @default(false)
    maxTeamSize        Int?

    categoryId  String
    organizerId String

    category  Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
    organizer User     @relation("OrganizerHackathons", fields: [organizerId], references: [id], onDelete: Restrict)

    rewards     HackathonReward[]
    submissions Submission[]
    bookmarks   HackathonBookmark[]

    createdAt        DateTime          @default(now())
    updatedAt        DateTime          @updatedAt
    hackathonWinners HackathonWinner[]

    @@index([categoryId])
    @@index([organizerId])
    @@index([status])
    @@index([isFeatured])
}

model HackathonReward {
    id          String     @id @default(cuid())
    hackathonId String
    title       String
    description String?
    rewardType  RewardType
    amount      Decimal?   @db.Decimal(10, 2)
    currency    String?
    rankOrder   Int?

    hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([hackathonId])
}

model HackathonWinner {
    id           String  @id @default(cuid())
    hackathonId  String
    submissionId String
    title        String?
    rankOrder    Int?

    hackathon  Hackathon  @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
    submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
}
