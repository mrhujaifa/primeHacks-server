model Hackathon {
    id               String @id @default(cuid())
    title            String
    slug             String @unique
    shortDescription String
    fullDescription  String

    logoUrl        String?
    bannerImageUrl String?
    websiteUrl     String?
    discordUrl     String?
    contactEmail   String?

    rules       String?
    eligibility String?

    prizePoolText   String?
    registrationFee Decimal @default(0) @db.Decimal(10, 2)
    currency        String  @default("USDT")

    maxTeamSize Int?

    registrationStartDate DateTime?
    registrationEndDate   DateTime?
    startDate             DateTime?
    endDate               DateTime?
    submissionDeadline    DateTime

    status        HackathonStatus @default(DRAFT)
    isFeatured    Boolean         @default(false)
    isPremiumOnly Boolean         @default(false)

    categoryId  String
    organizerId String

    category  Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
    organizer User     @relation("OrganizerHackathons", fields: [organizerId], references: [id], onDelete: Restrict)

    rewards          HackathonReward[]
    submissions      Submission[]
    bookmarks        HackathonBookmark[]
    hackathonWinners HackathonWinner[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([categoryId])
    @@index([organizerId])
    @@index([status])
    @@index([isFeatured])
    @@index([submissionDeadline])
}

model HackathonReward {
    id          String     @id @default(cuid())
    hackathonId String
    title       String
    description String?
    rewardType  RewardType
    amount      Decimal?   @db.Decimal(10, 2)
    currency    String?
    rankOrder   Int?

    hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([hackathonId])
}

model HackathonWinner {
    id           String  @id @default(cuid())
    hackathonId  String
    submissionId String
    title        String?
    rankOrder    Int?

    hackathon  Hackathon  @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
    submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
}
